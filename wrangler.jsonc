{
  "$schema": "node_modules/wrangler/config-schema.json",
  // 【配布用テンプレート】顧客が Deploy ボタンで自分のCFアカウントへ展開する単一Worker（§3）。
  // リソースID は記載しない＝CFが複製先アカウントに自動作成してバインド。
  "name": "baku-office",
  // v13：ビルド成果物は server/（entry.mjs + chunks・事前バンドル）と client/（静的アセット）に分離。
  //   no_bundle=true でビルド済モジュールをそのまま展開＝顧客側に node_modules / ビルド不要。
  //   base_dir=./server でモジュール探索を server 配下に限定（client のJSをWorkerに取り込まない）。
  // main は自走 cron 対応のラッパ（bo-entry.mjs）＝Astro の fetch に scheduled を足し、単一Workerが
  //   自分の /api/cron/drain を定期起動する（別途 scheduler Worker 不要＝顧客はCFを触らず自動更新等が動く）。
  "main": "./server/bo-entry.mjs",
  "base_dir": "./server",
  "no_bundle": true,
  "rules": [{ "type": "ESModule", "globs": ["**/*.js", "**/*.mjs"] }],
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": { "binding": "ASSETS", "directory": "./client" },
  "observability": { "enabled": true },
  // ネイティブ Cron Triggers（2分毎）。scheduled ハンドラ（bo-entry.mjs）が drain を自走起動＝
  //   自動更新・停止ビルド回収・スケジュールタスク・報告送信が顧客側で自動で回る。
  "triggers": { "crons": ["*/2 * * * *"] },

  // 自動プロビジョニング（公式推奨）：id・名前を省略し binding のみ。Deploy時にCFが自動作成する。
  // KVは単一（LICENSE）に集約：複数KVの自動命名が衝突（already exists）するのを避けるため。
  //   ファイルは LICENSE に "f/" prefix で保存（storage.ts の mediaKv フォールバック）。
  //   Astro session は未使用のため SESSION KV も不要（コードは独自HMACセッション）。
  "d1_databases": [{ "binding": "DB", "migrations_dir": "migrations","database_id": "3ccbed2a-dd0c-4f5c-9cf7-da7ce3d8d459","database_name": "baku-office" }],
  "kv_namespaces": [
    { "binding": "LICENSE","id": "7aa17b26335a4b7bb7dc1d608e17ebf9" }
  ],

  "vars": {
    // 当社ホストポータル（ライセンス取得・統合チェック・ログイン中継・検証鍵配布）。
    "HOST_BASE_URL": "https://baku-office-portal.baku-027.workers.dev"
  }
  // アクティベートは「アプリを開いて Google でログイン」（申込メールと突合）。secret/var の追加入力は不要。
  // ★ secret 投入は不要：MASTER_KEY は初回自動生成（団体のKVに保存）、ライセンス検証鍵はホストから自動取得、
  //   組織ログインは当社ホスト経由の中継（団体側のGoogle設定不要）。
  // AIを使う場合のみ、デプロイ後に管理画面「連携設定」で Gemini／（Pro）LINE・Claude のAPIキーを登録。
  // R2（高度モード・任意）：[[r2_buckets]] binding=MEDIA_R2（カード必要・§11）。
}
